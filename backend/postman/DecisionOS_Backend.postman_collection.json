{
  "info": {
    "name": "DecisionOS Spend Intelligence Backend",
    "_postman_id": "9a10e6c1-4d30-4b3b-a178-cc0be8e4f777",
    "description": "API collection for company monthly spend analytics endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "case_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Load Sample Spend Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases/samples"
      }
    },
    {
      "name": "List Spend Cases",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases"
      }
    },
    {
      "name": "Finance Review Queue",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases/review-queue"
      }
    },
    {
      "name": "Compare Periods",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases/compare-periods?period_a_start=2026-01-01&period_a_end=2026-01-31&period_b_start=2026-02-01&period_b_end=2026-02-28"
      }
    },
    {
      "name": "Create Spend Case (JSON)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profile\": {\n    \"company_name\": \"Postman Company\",\n    \"monthly_revenue\": 220000,\n    \"monthly_spend\": 158000,\n    \"planned_budget\": 165000,\n    \"cash_reserve\": 84000,\n    \"budget_variance_ratio\": 0.11,\n    \"anomalous_transactions_30d\": 2,\n    \"runway_months\": 7,\n    \"late_payments_90d\": 1,\n    \"invoice_match_rate\": 0.94,\n    \"books_verified\": true,\n    \"documents\": [\"general_ledger_jan.csv\", \"vendor_aging_jan.csv\", \"budget_plan_q1.json\"]\n  }\n}"
        },
        "url": "{{base_url}}/cases/create"
      }
    },
    {
      "name": "Create Spend Case (Upload)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {"key": "company_name", "value": "Upload Company", "type": "text"},
            {"key": "monthly_revenue", "value": "250000", "type": "text"},
            {"key": "monthly_spend", "value": "175000", "type": "text"},
            {"key": "planned_budget", "value": "180000", "type": "text"},
            {"key": "cash_reserve", "value": "72000", "type": "text"},
            {"key": "budget_variance_ratio", "value": "0.18", "type": "text"},
            {"key": "anomalous_transactions_30d", "value": "3", "type": "text"},
            {"key": "runway_months", "value": "6", "type": "text"},
            {"key": "late_payments_90d", "value": "1", "type": "text"},
            {"key": "invoice_match_rate", "value": "0.92", "type": "text"},
            {"key": "books_verified", "value": "false", "type": "text"},
            {"key": "files", "type": "file", "src": ""}
          ]
        },
        "url": "{{base_url}}/cases/create-with-upload"
      }
    },
    {
      "name": "Finance Decision",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{base_url}}/cases/{{case_id}}/human-decision?decision=WATCHLIST"
      }
    }
  ]
}
