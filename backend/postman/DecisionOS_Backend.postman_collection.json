{
  "info": {
    "name": "DecisionOS Backend",
    "_postman_id": "9a10e6c1-4d30-4b3b-a178-cc0be8e4f777",
    "description": "Hackathon API collection for DecisionOS backend endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "case_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Load Sample Cases",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases/samples"
      }
    },
    {
      "name": "List Cases",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases"
      }
    },
    {
      "name": "Review Queue",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/cases/review-queue"
      }
    },
    {
      "name": "Create Case (JSON)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"applicant\": {\n    \"name\": \"Postman Applicant\",\n    \"monthly_income\": 4300,\n    \"monthly_expenses\": 2200,\n    \"requested_amount\": 7000,\n    \"existing_debt\": 900,\n    \"credit_utilization\": 0.31,\n    \"delinquencies_12m\": 0,\n    \"employment_months\": 24,\n    \"overdrafts_90d\": 0,\n    \"income_verified\": true,\n    \"documents\": [\"id_document.pdf\", \"bank_statement_jan.pdf\", \"income_proof.pdf\"]\n  }\n}"
        },
        "url": "{{base_url}}/cases/create"
      }
    },
    {
      "name": "Create Case (Upload)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "name",
              "value": "Upload Applicant",
              "type": "text"
            },
            {
              "key": "monthly_income",
              "value": "5000",
              "type": "text"
            },
            {
              "key": "monthly_expenses",
              "value": "2500",
              "type": "text"
            },
            {
              "key": "requested_amount",
              "value": "10000",
              "type": "text"
            },
            {
              "key": "existing_debt",
              "value": "1400",
              "type": "text"
            },
            {
              "key": "credit_utilization",
              "value": "0.42",
              "type": "text"
            },
            {
              "key": "delinquencies_12m",
              "value": "1",
              "type": "text"
            },
            {
              "key": "employment_months",
              "value": "18",
              "type": "text"
            },
            {
              "key": "overdrafts_90d",
              "value": "0",
              "type": "text"
            },
            {
              "key": "income_verified",
              "value": "false",
              "type": "text"
            },
            {
              "key": "files",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": "{{base_url}}/cases/create-with-upload"
      }
    },
    {
      "name": "Human Decision",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{base_url}}/cases/{{case_id}}/human-decision?decision=APPROVE"
      }
    }
